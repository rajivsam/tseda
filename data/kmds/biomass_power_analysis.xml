<owl:NamedIndividual rdf:about="#biomass_per_hour_generation_4_year_data_SPAIN">
  <rdf:type rdf:resource="#KnowledgeExtractionExperimentationWorkflow"/>
  <has_exploratory_observations rdf:resource="#exploratoryobservation1"/>
  <has_exploratory_observations rdf:resource="#exploratoryobservation2"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#exploratoryobservation1">
  <rdf:type rdf:resource="#ExploratoryObservation"/>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This analysis uses Singular Spectrum Analysis (SSA) to summarize hourly biomass power generation data from Kaggle. The SSA method decomposes the data into a dominant trend component (94% variability) and a seasonal component (3.5% variability), with change points identified by a peak-finding algorithm. Frequency components are also discernible. The Durbin-Watson test (statistic 1.5-2.5) is suggested for identifying the noise term by checking for serial correlation in residuals.</finding>
  <finding_sequence rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</finding_sequence>
  <exploratory_observation_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Data Quality Observation</exploratory_observation_type>
  <intent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DATA_UNDERSTANDING</intent>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#exploratoryobservation2">
  <rdf:type rdf:resource="#ExploratoryObservation"/>
  <finding rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Just like that, a 4 year history of power generation from biomass sources has been analyzed.</finding>
  <finding_sequence rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</finding_sequence>
  <exploratory_observation_type rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Data Quality Observation</exploratory_observation_type>
  <intent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DATA_UNDERSTANDING</intent>
</owl:NamedIndividual>


